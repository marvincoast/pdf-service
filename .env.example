# === PDF Service — Variáveis de Ambiente ===

# Ollama API endpoint
OLLAMA_API=http://127.0.0.1:11434

# Modelo LLM (phi3:mini, qwen2.5:3b, llama3.2:3b, etc.)
LLM_MODEL=phi3:mini

# Tamanho máximo do arquivo PDF (em MB)
MAX_FILE_SIZE_MB=15

# Máximo de caracteres enviados ao LLM
MAX_TEXT_CHARS=4000

# Timeout para resposta do Ollama (segundos)
OLLAMA_TIMEOUT=90

# Porta da aplicação
PORT=8080
